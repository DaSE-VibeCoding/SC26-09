{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pelican",
  "version": "0.1.0",
  "identifier": "app.pelican.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pelican",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 640,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
